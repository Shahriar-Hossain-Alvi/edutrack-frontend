{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": true, 
    "noEmit": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*"]
}


